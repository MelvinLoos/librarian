// schema.prisma

datasource db {
  provider = "sqlite"
  // In Prisma 7+, the url property is removed from here.
  // Connection strings are now managed via prisma.config.ts or the PrismaClient constructor.
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// 1. IAM CONTEXT (Librarian Specific Tables - Managed by Prisma Migrations)
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("READER") // ADMIN, CONTRIBUTOR, READER
  createdAt    DateTime @default(now())
  
  readingStates LibrarianReadingProgress[]
  @@map("librarian_users")
}

model LibrarianReadingProgress {
  id          Int      @id @default(autoincrement())
  userId      String   // Changed from Int to String to match User model!
  bookId      Int
  currentPage Int      @default(0)
  totalPages  Int      @default(0)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

// ---------------------------------------------------------------------------
// 2. CATALOG CONTEXT (Legacy Calibre Mapping - FROZEN SCHEMA)
// ---------------------------------------------------------------------------

model Book {
  id           Int       @id @default(autoincrement())
  title        String    @default("Unknown")
  sort         String?
  timestamp    DateTime? @default(now())
  pubdate      DateTime?
  seriesIndex  Float?    @default(1.0) @map("series_index")
  authorSort   String?   @map("author_sort")
  uuid         String?
  hasCover     Boolean?  @default(false) @map("has_cover")
  lastModified DateTime  @default(now()) @updatedAt @map("last_modified")
  path         String?

  // Relationships mapping to Calibre Link Tables
  authors      BookAuthorLink[]
  formats      Data[]

  tags         BookTagLink[]
  series       BookSeriesLink[]
  comments     Comment[]
  
  readingStates LibrarianReadingProgress[]
  @@map("books")
}

model Author {
  id    Int    @id @default(autoincrement())
  name  String
  sort  String?
  link  String?

  books BookAuthorLink[]

  @@map("authors")
}

model BookAuthorLink {
  id       Int @id @default(autoincrement())
  bookId   Int @map("book")
  authorId Int @map("author")

  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("books_authors_link")
}

// ---------------------------------------------------------------------------
// 3. STORAGE CONTEXT (Legacy Calibre Mapping - FROZEN SCHEMA)
// ---------------------------------------------------------------------------

model Data {
  id               Int    @id @default(autoincrement())
  bookId           Int    @map("book")
  format           String 
  uncompressedSize Int    @map("uncompressed_size")
  name             String 

  book             Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("data")
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String

  books BookTagLink[]

  @@map("tags")
}

model BookTagLink {
  id       Int @id @default(autoincrement())
  bookId   Int @map("book")
  tagId    Int @map("tag")

  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("books_tags_link")
}

model Series {
  id    Int    @id @default(autoincrement())
  name  String
  sort  String?

  books BookSeriesLink[]

  @@map("series")
}

model BookSeriesLink {
  id       Int @id @default(autoincrement())
  bookId   Int @map("book")
  seriesId Int @map("series")

  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  series   Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@map("books_series_link")
}

model Comment {
  id       Int    @id @default(autoincrement())
  bookId   Int    @map("book")
  text     String

  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("comments")
}