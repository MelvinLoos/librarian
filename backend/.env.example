# Environment variables for the Librarian Backend

# The base path for your Calibre library (where metadata.db and authors/ folders are located)
# On Linux/macOS, use absolute paths. On Windows, use forward slashes or escaped backslashes.
CALIBRE_LIBRARY_PATH="./"

# Database URL for Prisma. Relative to the /backend/prisma directory.
# Default: assumes metadata.db is in the project root (one level up from /backend)
DATABASE_URL="file:../../metadata.db"

# JWT Secrets for Authentication. Change these to long random strings in production!
JWT_SECRET="develop-secret-key-replace-in-production"
JWT_REFRESH_SECRET="develop-refresh-secret-replace-in-production"

# Environment
NODE_ENV="development"
PORT=3001
